# Copy to .env.local and fill in. Never commit .env.local.
TRAVELPAYOUTS_TOKEN=     # API token — travelpayouts.com → Profile → API token
TRAVELPAYOUTS_MARKER=    # Affiliate marker — travelpayouts.com → bottom-left of dashboard
ANTHROPIC_API_KEY=       # Anthropic Claude API key (AI search / discover)
UNSPLASH_ACCESS_KEY=     # Unsplash API access key (city photos)
SENDGRID_API_KEY=        # SendGrid API key (price alert emails)
